{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiengine/contracts/instrument_master/1.0.0",
  "title": "Instrument Master",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "as_of_time",
    "ingested_at",
    "source_name",
    "source_record_id",
    "schema_version",
    "instrument_id",
    "ticker",
    "exchange",
    "currency",
    "is_active"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "as_of_time": { "type": "string", "format": "date-time" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "source_name": { "type": "string", "minLength": 1 },
    "source_record_id": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "instrument_id": { "type": "string", "minLength": 1 },
    "ticker": { "type": "string", "minLength": 1 },
    "exchange": { "type": "string", "minLength": 1 },
    "isin": { "type": ["string", "null"] },
    "cusip": { "type": ["string", "null"] },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "sector": { "type": ["string", "null"] },
    "industry": { "type": ["string", "null"] },
    "is_active": { "type": "boolean" }
  }
}
